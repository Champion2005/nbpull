{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": ".github/hooks/scripts/session-start.sh",
        "timeout": 15
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": ".github/hooks/scripts/session-stop.sh",
        "timeout": 10
      }
    ],
    "PreCompact": [
      {
        "type": "command",
        "command": ".github/hooks/scripts/pre-compact.sh",
        "timeout": 10
      }
    ]
  }
}
